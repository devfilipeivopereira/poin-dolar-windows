                                    <Button Content="DOM" ToolTip="DOM / Book" Tag="3" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                                    <Button Content="Tape" ToolTip="Times and trades" Tag="4" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                                    <Button Content="Grafico" ToolTip="Grafico nativo com niveis" Tag="9" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource TopNavGroupBorderStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="TopNavFlowLabel" Text="Fluxo" Style="{StaticResource TopNavGroupStyle}" />
