<Window x:Class="RtdDolarNative.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RtdDolarNative"
        Height="520"
        Width="920"
        MinHeight="460"
        MinWidth="760"
        Background="#F3F5F7"
        FontFamily="Segoe UI"
        FontSize="13">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#17212B" Padding="16,12">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="ConnectButton"
                            Width="116"
                            Height="32"
                            Margin="0,0,8,0"
                            Click="ConnectButton_Click"
                            Content="Desconectar" />
                    <Button x:Name="ManualButton"
                            Width="112"
                            Height="32"
                            Click="ManualButton_Click"
                            Content="Modo manual" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="RTD Dolar Native"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,16,0" />
                    <Border x:Name="StatusBadgeBorder"
                            CornerRadius="4"
                            Background="#9AA3AD"
                            Padding="10,4"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   Text="starting" />
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Background="White"
                    BorderBrush="#DDE3EA"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14"
                    Margin="0,0,0,14">
                <UniformGrid Columns="6">
                    <StackPanel>
                        <TextBlock Text="Ativo" Foreground="#65717E" />
                        <TextBlock x:Name="AssetText" FontWeight="SemiBold" Text="-" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Processo" Foreground="#65717E" />
                        <TextBlock x:Name="ArchitectureText" FontWeight="SemiBold" Text="-" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Hora Profit" Foreground="#65717E" />
                        <TextBlock x:Name="ProfitTimeText" FontWeight="SemiBold" Text="-" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Ultimo update" Foreground="#65717E" />
                        <TextBlock x:Name="LocalUpdateText" FontWeight="SemiBold" Text="-" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Idade" Foreground="#65717E" />
                        <TextBlock x:Name="SnapshotAgeText" FontWeight="SemiBold" Text="-" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Updates" Foreground="#65717E" />
                        <TextBlock x:Name="UpdatesText" FontWeight="SemiBold" Text="0" />
                    </StackPanel>
                </UniformGrid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Background="White"
                    BorderBrush="#DDE3EA"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="20"
                    Margin="0,0,14,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Prova RTD"
                               Foreground="#27313A"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <Grid Grid.Row="1" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="ULT"
                                       Foreground="#65717E"
                                       FontSize="14" />
                            <TextBlock x:Name="PriceText"
                                       Text="-"
                                       Foreground="#0B6E4F"
                                       FontSize="52"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="RawPriceText"
                                       Text="-"
                                       Foreground="#65717E" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="VOL"
                                       Foreground="#65717E"
                                       FontSize="14" />
                            <TextBlock x:Name="VolumeText"
                                       Text="-"
                                       Foreground="#315A8C"
                                       FontSize="34"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="RawVolumeText"
                                       Text="-"
                                       Foreground="#65717E" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Grid.Row="2"
                               Text="Fluxo: Profit -> RTD COM -> thread STA -> latest snapshot -> WPF"
                               Foreground="#65717E" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Background="White"
                    BorderBrush="#DDE3EA"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="18">
                <StackPanel>
                    <TextBlock Text="Diagnostico"
                               Foreground="#27313A"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16" />
                    <TextBlock Text="Campos assinados" Foreground="#65717E" />
                    <TextBlock x:Name="FieldsText"
                               Text="-"
                               TextWrapping="Wrap"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14" />
                    <TextBlock Text="Poll RTD" Foreground="#65717E" />
                    <TextBlock x:Name="PollText"
                               Text="-"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14" />
                    <TextBlock Text="Erro recente" Foreground="#65717E" />
                    <TextBlock x:Name="LastErrorText"
                               Text="-"
                               Foreground="#A13D2D"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#E8EDF2" Padding="16,8">
            <TextBlock Foreground="#65717E"
                       Text="MVP nativo low-latency: sem HTML, sem WebSocket e sem SQLite no caminho quente." />
        </Border>
    </Grid>
</Window>
