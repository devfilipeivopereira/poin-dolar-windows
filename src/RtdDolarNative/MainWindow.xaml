                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Venda" Binding="{Binding AskVol}" Width="58" CellStyle="{StaticResource DomLadderCenterCellStyle}" />
                                            <DataGridTextColumn Header="Preco" Binding="{Binding PriceText}" Width="82" CellStyle="{StaticResource DomLadderCenterCellStyle}" />
                                            <DataGridTextColumn Header="Compra" Binding="{Binding BidVol}" Width="64" CellStyle="{StaticResource DomLadderCenterCellStyle}" />
                                            <DataGridTextColumn Header="Niveis" Binding="{Binding Markings}" Width="*" CellStyle="{StaticResource DomLadderLeftCellStyle}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Tape" FontSize="15" FontWeight="Bold" Margin="0,0,0,8" />
                                    <DataGrid x:Name="DashboardTapeGrid"
                                              Grid.Row="1"
                                              AutoGenerateColumns="False"
                                              RowHeight="21"
                                              ColumnHeaderHeight="24"
                                              CellStyle="{StaticResource CenteredDataGridCellStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Hora" Binding="{Binding Time}" Width="76" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" EditingElementStyle="{StaticResource CenteredDataGridEditingElementStyle}" />
                                            <DataGridTextColumn Header="Preco" Binding="{Binding Price}" Width="82" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" EditingElementStyle="{StaticResource CenteredDataGridEditingElementStyle}" />
                                            <DataGridTextColumn Header="Qtd" Binding="{Binding Quantity}" Width="56" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" EditingElementStyle="{StaticResource CenteredDataGridEditingElementStyle}" />
                                            <DataGridTextColumn Header="Agr" Binding="{Binding Aggressor}" Width="60" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" EditingElementStyle="{StaticResource CenteredDataGridEditingElementStyle}" />
                                            <DataGridTextColumn Header="Qual" Binding="{Binding Quality}" Width="*" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" EditingElementStyle="{StaticResource CenteredDataGridEditingElementStyle}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="10">
