                                                          VerticalContentAlignment="Center"
                                                          Checked="ChartLineVisibility_Checked"
                                                          Unchecked="ChartLineVisibility_Checked" />
                                                <CheckBox x:Name="ChartShowGarchLevelsCheckBox"
                                                          Content="GARCH"
