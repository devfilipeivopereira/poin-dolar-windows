                                              Grid.Row="1"
                                              AutoGenerateColumns="False"
                                              CellStyle="{StaticResource DirectionalDataGridCellStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Preco" Binding="{Binding Price}" Width="82" />
                                            <DataGridTextColumn Header="Nivel" Binding="{Binding Label}" Width="128" />
                                            <DataGridTextColumn Header="Fonte" Binding="{Binding Source}" Width="82" />
                                            <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="56" />
                                            <DataGridTextColumn Header="Dist" Binding="{Binding Distance}" Width="70" />
                                            <DataGridTextColumn Header="Evidencia" Binding="{Binding Evidence}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1.05*" />
                                <RowDefinition Height="0.9*" />
                                <RowDefinition Height="0.7*" />
                            </Grid.RowDefinitions>

                            <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                        <DockPanel Margin="0,0,0,4" LastChildFill="False">
                                            <TextBlock Text="DOM" DockPanel.Dock="Left" FontSize="15" FontWeight="Bold" />
                                            <TextBlock Text="Pontos" DockPanel.Dock="Right" Foreground="{StaticResource Muted}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right" />
                                        </DockPanel>
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Disabled"
                                                      Height="30"
                                                      CanContentScroll="False"
                                                      PanningMode="HorizontalOnly"
                                                      Focusable="False">
                                            <StackPanel Orientation="Horizontal">
                                                <CheckBox x:Name="DashboardDomShowBaseCheckBox" Content="Base" Tag="{StaticResource ChartLineKeyLevelsBrush}" Style="{StaticResource TopNavChartLineCheckBoxStyle}" Checked="DomAnnotationVisibility_Checked" Unchecked="DomAnnotationVisibility_Checked" />
                                                <CheckBox x:Name="DashboardDomShowGarmanCheckBox" Content="GK" Tag="{StaticResource ChartLineGarmanBrush}" Style="{StaticResource TopNavChartLineCheckBoxStyle}" Checked="DomAnnotationVisibility_Checked" Unchecked="DomAnnotationVisibility_Checked" />
                                                <CheckBox x:Name="DashboardDomShowGaussCheckBox" Content="Gauss" Tag="{StaticResource ChartLineGaussBrush}" Style="{StaticResource TopNavChartLineCheckBoxStyle}" Checked="DomAnnotationVisibility_Checked" Unchecked="DomAnnotationVisibility_Checked" />
                                                <CheckBox x:Name="DashboardDomShowStdDevCheckBox" Content="Desvio" Tag="{StaticResource ChartLineStdDevBrush}" Style="{StaticResource TopNavChartLineCheckBoxStyle}" Checked="DomAnnotationVisibility_Checked" Unchecked="DomAnnotationVisibility_Checked" />
                                                <CheckBox x:Name="DashboardDomShowGarchCheckBox" Content="GARCH" Tag="{StaticResource ChartLineGarchBrush}" Style="{StaticResource TopNavChartLineCheckBoxStyle}" Checked="DomAnnotationVisibility_Checked" Unchecked="DomAnnotationVisibility_Checked" />
                                                <CheckBox x:Name="DashboardDomShowPercentCheckBox" Content="%" Tag="{StaticResource ChartLinePercentBrush}" Style="{StaticResource TopNavChartLineCheckBoxStyle}" Checked="DomAnnotationVisibility_Checked" Unchecked="DomAnnotationVisibility_Checked" />
                                                <CheckBox x:Name="DashboardDomShowMaxMin7CheckBox" Content="MaxMin7" Tag="{StaticResource ChartLineMaxMin7Brush}" Style="{StaticResource TopNavChartLineCheckBoxStyle}" Checked="DomAnnotationVisibility_Checked" Unchecked="DomAnnotationVisibility_Checked" />
                                                <CheckBox x:Name="DashboardDomShowProfileCheckBox" Content="Perfil" Tag="{StaticResource ChartLineProfileBrush}" Style="{StaticResource TopNavChartLineCheckBoxStyle}" Checked="DomAnnotationVisibility_Checked" Unchecked="DomAnnotationVisibility_Checked" />
                                                <CheckBox x:Name="DashboardDomShowTechnicalCheckBox" Content="Tecnico" Tag="{StaticResource ChartLineTechnicalBrush}" Style="{StaticResource TopNavChartLineCheckBoxStyle}" Checked="DomAnnotationVisibility_Checked" Unchecked="DomAnnotationVisibility_Checked" />
                                                <CheckBox x:Name="DashboardDomShowFlowCheckBox" Content="Fluxo" Tag="{StaticResource ChartLineConfluenceBrush}" Style="{StaticResource TopNavChartLineCheckBoxStyle}" Checked="DomAnnotationVisibility_Checked" Unchecked="DomAnnotationVisibility_Checked" />
                                            </StackPanel>
                                        </ScrollViewer>
                                    </StackPanel>
                                    <DataGrid x:Name="DashboardDomGrid"
                                              Grid.Row="1"
