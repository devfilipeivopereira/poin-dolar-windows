                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Ativos cadastrados" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,16,0" />
