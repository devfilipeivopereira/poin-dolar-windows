                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Sinais" Foreground="{StaticResource Muted}" />
                                <TextBlock x:Name="ScannerSignalCountText" Text="0" Foreground="{StaticResource Accent}" FontWeight="Bold" />
                            </StackPanel>

                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Foco" Foreground="{StaticResource Muted}" />
                                <TextBlock x:Name="ScannerFocusText" Text="-" FontWeight="Bold" />
                            </StackPanel>

                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Atualizar" Click="RefreshScannerButton_Click" />
                                <Button Content="Oportunidades" Tag="16" Click="TopNavButton_Click" Margin="0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="ScannerGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              SelectionMode="Single"
                              MouseDoubleClick="ScannerGrid_MouseDoubleClick"
                              RowStyle="{StaticResource StatusDataGridRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="48" />
                            <DataGridTextColumn Header="Ativo" Binding="{Binding Asset}" Width="120" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="95" />
                            <DataGridTextColumn Header="ULT" Binding="{Binding Last}" Width="90" />
                            <DataGridTextColumn Header="Bid / Ask" Binding="{Binding BidAsk}" Width="140" />
                            <DataGridTextColumn Header="Snapshot" Binding="{Binding SnapshotAge}" Width="90" />
                            <DataGridTextColumn Header="C/B/T" Binding="{Binding Channels}" Width="70" />
                            <DataGridTextColumn Header="Qualidade" Binding="{Binding Quality}" Width="125" />
                            <DataGridTextColumn Header="Setup" Binding="{Binding BestSetup}" Width="150" />
                            <DataGridTextColumn Header="Direcao" Binding="{Binding Direction}" Width="82" />
                            <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="62" />
                            <DataGridTextColumn Header="Nivel" Binding="{Binding Level}" Width="155" />
                            <DataGridTextColumn Header="Dist" Binding="{Binding Distance}" Width="76" />
                            <DataGridTextColumn Header="Delta" Binding="{Binding Delta}" Width="92" />
                            <DataGridTextColumn Header="VWAP" Binding="{Binding VwapDistance}" Width="82" />
                            <DataGridTextColumn Header="Leitura" Binding="{Binding Read}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Mapa de Fluxo">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource Panel}"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1"
                            Padding="12"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.4*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Mapa de Fluxo" FontSize="16" FontWeight="Bold" />
                                <TextBlock x:Name="FlowMapStateText"
                                           Text="-"
                                           Foreground="{StaticResource Muted}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Ativo" Foreground="{StaticResource Muted}" />
                                <TextBlock x:Name="FlowMapAssetText" Text="-" FontWeight="Bold" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Delta" Foreground="{StaticResource Muted}" />
                                <TextBlock x:Name="FlowMapDeltaText" Text="-" Foreground="{StaticResource Accent}" FontWeight="Bold" />
                            </StackPanel>

                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Pressao" Foreground="{StaticResource Muted}" />
                                <TextBlock x:Name="FlowMapBiasText" Text="-" FontWeight="Bold" />
                            </StackPanel>

                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Atualizar" Click="RefreshFlowMapButton_Click" />
                                <Button Content="DOM / Book" Tag="3" Click="TopNavButton_Click" Margin="0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.45*" />
                            <ColumnDefinition Width="0.95*" />
                        </Grid.ColumnDefinitions>

                        <DataGrid x:Name="FlowMapGrid"
                                  AutoGenerateColumns="False"
                                  RowStyle="{StaticResource FlowMapDataGridRowStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Zona" Binding="{Binding Zone}" Width="64" />
                                <DataGridTextColumn Header="Preco" Binding="{Binding Price}" Width="92" />
                                <DataGridTextColumn Header="Compra" Binding="{Binding BidSize}" Width="86" />
                                <DataGridTextColumn Header="Venda" Binding="{Binding AskSize}" Width="86" />
                                <DataGridTextColumn Header="Imb" Binding="{Binding Imbalance}" Width="70" />
                                <DataGridTemplateColumn Header="Liquidez" Width="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Width="142" Height="14" VerticalAlignment="Center">
                                                <Border Width="{Binding BidBarWidth}" Height="12" Background="{StaticResource Accent}" />
                                                <Border Width="{Binding AskBarWidth}" Height="12" Background="{StaticResource Danger}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Niveis" Binding="{Binding Levels}" Width="210" />
                                <DataGridTextColumn Header="Leitura" Binding="{Binding Read}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Grid Grid.Column="1" Margin="10,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="160" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="190" />
                            </Grid.RowDefinitions>

                            <DataGrid x:Name="FlowMapSummaryGrid"
                                      AutoGenerateColumns="False"
                                      Margin="0,0,0,10">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Item" Binding="{Binding Name}" Width="86" />
                                    <DataGridTextColumn Header="Valor" Binding="{Binding Value}" Width="110" />
                                    <DataGridTextColumn Header="Detalhe" Binding="{Binding Detail}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <DataGrid x:Name="FlowMapLevelsGrid"
                                      Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      Margin="0,0,0,10">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Preco" Binding="{Binding Price}" Width="88" />
                                    <DataGridTextColumn Header="Nivel" Binding="{Binding Label}" Width="140" />
                                    <DataGridTextColumn Header="Dist" Binding="{Binding Distance}" Width="75" />
                                    <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="62" />
                                    <DataGridTextColumn Header="Fonte" Binding="{Binding Source}" Width="105" />
                                    <DataGridTextColumn Header="Leitura" Binding="{Binding Read}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <DataGrid x:Name="FlowMapSignalsGrid"
                                      Grid.Row="2"
                                      AutoGenerateColumns="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Hora" Binding="{Binding LocalTimeText}" Width="90" />
                                    <DataGridTextColumn Header="Setup" Binding="{Binding Setup}" Width="135" />
                                    <DataGridTextColumn Header="Direcao" Binding="{Binding Direction}" Width="80" />
                                    <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="62" />
                                    <DataGridTextColumn Header="Nivel" Binding="{Binding LevelName}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Indicadores">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource Panel}"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1"
                            Padding="12"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Indicadores Quant" FontSize="16" FontWeight="Bold" />
                                <TextBlock x:Name="IndicatorsStateText"
                                           Text="-"
                                           Foreground="{StaticResource Muted}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Ativo" Foreground="{StaticResource Muted}" />
                                <TextBlock x:Name="IndicatorsAssetText" Text="-" FontWeight="Bold" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Regime" Foreground="{StaticResource Muted}" />
                                <TextBlock x:Name="IndicatorsRegimeText" Text="-" FontWeight="Bold" />
                            </StackPanel>

                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Sinais Quant" Foreground="{StaticResource Muted}" />
                                <TextBlock x:Name="IndicatorsSignalCountText" Text="0" Foreground="{StaticResource Accent}" FontWeight="Bold" />
                            </StackPanel>

                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Atualizar" Click="RefreshIndicatorsButton_Click" />
                                <Button Content="Oportunidades" Tag="16" Click="TopNavButton_Click" Margin="0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.95*" />
                            <ColumnDefinition Width="1.45*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="170" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="210" />
                        </Grid.RowDefinitions>

                        <DataGrid x:Name="IndicatorsSummaryGrid"
                                  Grid.ColumnSpan="2"
                                  AutoGenerateColumns="False"
                                  Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Item" Binding="{Binding Name}" Width="130" />
                                <DataGridTextColumn Header="Valor" Binding="{Binding Value}" Width="170" />
                                <DataGridTextColumn Header="Detalhe" Binding="{Binding Detail}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <DataGrid x:Name="IndicatorsTechnicalGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  Margin="0,0,10,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Indicador" Binding="{Binding Indicator}" Width="145" />
                                <DataGridTextColumn Header="Valor" Binding="{Binding Value}" Width="95" />
                                <DataGridTextColumn Header="Estado" Binding="{Binding State}" Width="130" />
                                <DataGridTextColumn Header="Fonte" Binding="{Binding Source}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <DataGrid x:Name="IndicatorsSignalsGrid"
                                  Grid.Row="1"
                                  Grid.Column="1"
                                  AutoGenerateColumns="False"
                                  Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Setup" Binding="{Binding Setup}" Width="155" />
                                <DataGridTextColumn Header="Direcao" Binding="{Binding Direction}" Width="80" />
                                <DataGridTextColumn Header="Preco" Binding="{Binding Price}" Width="90" />
                                <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="64" />
                                <DataGridTextColumn Header="Nivel" Binding="{Binding Level}" Width="150" />
                                <DataGridTextColumn Header="Edge" Binding="{Binding Edge}" Width="185" />
                                <DataGridTextColumn Header="Estado" Binding="{Binding TechnicalState}" Width="145" />
                                <DataGridTextColumn Header="Motivos" Binding="{Binding Reasons}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <DataGrid x:Name="IndicatorsStatsGrid"
                                  Grid.Row="2"
                                  AutoGenerateColumns="False"
                                  Margin="0,0,10,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Metrica" Binding="{Binding Metric}" Width="130" />
                                <DataGridTextColumn Header="Janela" Binding="{Binding Window}" Width="70" />
                                <DataGridTextColumn Header="Pontos" Binding="{Binding Points}" Width="90" />
                                <DataGridTextColumn Header="%" Binding="{Binding Percent}" Width="80" />
                                <DataGridTextColumn Header="Percentil" Binding="{Binding Percentile}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <DataGrid x:Name="IndicatorsBacktestGrid"
                                  Grid.Row="2"
                                  Grid.Column="1"
                                  AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Multiplo" Binding="{Binding Multiplier}" Width="90" />
                                <DataGridTextColumn Header="Amostras" Binding="{Binding Samples}" Width="90" />
                                <DataGridTextColumn Header="Toques" Binding="{Binding Touches}" Width="80" />
                                <DataGridTextColumn Header="Reversoes" Binding="{Binding Reversals}" Width="90" />
                                <DataGridTextColumn Header="Taxa toque" Binding="{Binding TouchRate}" Width="100" />
                                <DataGridTextColumn Header="Taxa reversao" Binding="{Binding ReversalRate}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
