                                Tag="13"
                                Click="TopNavButton_Click"
                                Style="{StaticResource DashboardWorkflowButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="2 RTD" Foreground="{StaticResource Muted}" FontWeight="Bold" />
                                <TextBlock x:Name="WorkflowRtdValueText" Text="-" FontSize="15" FontWeight="Bold" Margin="0,4,0,0" />
                                <TextBlock x:Name="WorkflowRtdStateText" Text="-" Foreground="{StaticResource Muted}" Margin="0,3,0,0" />
