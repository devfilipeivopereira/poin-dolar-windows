<Window x:Class="RtdDolarNative.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:charts="clr-namespace:RtdDolarNative.Charts"
        Title="Poin Dolar Windows"
        Height="820"
        Width="1380"
        MinHeight="720"
        MinWidth="1120"
        Background="#000000"
        FontFamily="Consolas"
        FontSize="12">
    <Window.Resources>
        <SolidColorBrush x:Key="Bg" Color="#000000" />
        <SolidColorBrush x:Key="Panel" Color="#0B0C0A" />
        <SolidColorBrush x:Key="Panel2" Color="#111411" />
        <SolidColorBrush x:Key="InputBg" Color="#050605" />
        <SolidColorBrush x:Key="Border" Color="#303844" />
        <SolidColorBrush x:Key="GridLine" Color="#222A33" />
        <SolidColorBrush x:Key="Text" Color="#E6EDF3" />
        <SolidColorBrush x:Key="Muted" Color="#A9B3BF" />
        <SolidColorBrush x:Key="Accent" Color="#00E676" />
        <SolidColorBrush x:Key="Warn" Color="#FFB800" />
        <SolidColorBrush x:Key="Danger" Color="#FF3B30" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Panel2}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="MinHeight" Value="28" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridLine}" />
            <Setter Property="RowBackground" Value="{StaticResource InputBg}" />
            <Setter Property="AlternatingRowBackground" Value="{StaticResource Panel}" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AutoGenerateColumns" Value="True" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource Bg}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{StaticResource Panel2}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinHeight" Value="34" />
        </Style>

        <Style x:Key="TopNavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="78" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="HiddenMainTabItemStyle" TargetType="TabItem">
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,0,1"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Poin Dolar Windows"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,14,0" />
                    <Border x:Name="StatusBadgeBorder"
                            Background="#303844"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1"
                            Padding="10,4">
                        <TextBlock x:Name="StatusText" Text="starting" FontWeight="Bold" />
                    </Border>
                </StackPanel>

                <UniformGrid Grid.Column="1" Columns="8" Margin="22,0" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Ativo" Foreground="{StaticResource Muted}" />
                        <TextBlock x:Name="AssetText" Text="-" FontWeight="Bold" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="ULT" Foreground="{StaticResource Muted}" />
                        <TextBlock x:Name="PriceText" Text="-" Foreground="{StaticResource Accent}" FontSize="18" FontWeight="Bold" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Bid / Ask" Foreground="{StaticResource Muted}" />
                        <TextBlock x:Name="BidAskText" Text="-" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Volume" Foreground="{StaticResource Muted}" />
                        <TextBlock x:Name="VolumeText" Text="-" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Hora Profit" Foreground="{StaticResource Muted}" />
                        <TextBlock x:Name="ProfitTimeText" Text="-" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Snapshot" Foreground="{StaticResource Muted}" />
                        <TextBlock x:Name="SnapshotAgeText" Text="-" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Updates" Foreground="{StaticResource Muted}" />
                        <TextBlock x:Name="UpdatesText" Text="0" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Processo" Foreground="{StaticResource Muted}" />
                        <TextBlock x:Name="ArchitectureText" Text="-" />
                    </StackPanel>
                </UniformGrid>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ConnectButton" Content="Desconectar" Click="ConnectButton_Click" />
                    <Button x:Name="ManualButton" Content="Modo manual" Click="ManualButton_Click" />
                    <Button x:Name="LoadCsvButton" Content="Carregar CSV" Click="LoadCsvButton_Click" PreviewMouseLeftButtonDown="LoadCsvButton_PreviewMouseLeftButtonDown" />
                    <Button x:Name="RecalcButton" Content="Calcular" Click="RecalcButton_Click" Margin="0" />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel x:Name="TopNavigation"
                    DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="12,12,12,0">
            <Button Content="Ativos" Tag="0" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
            <Button Content="Cotacao" Tag="1" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
            <Button Content="DOM / Book" Tag="2" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" MinWidth="110" />
            <Button Content="Tape" Tag="3" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
            <Button Content="Order Flow" Tag="4" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" MinWidth="110" />
            <Button Content="Volume Profile" Tag="5" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" MinWidth="140" />
            <Button Content="Setups" Tag="6" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
            <Button Content="Niveis" Tag="7" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
            <Button Content="Grafico" Tag="8" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
            <Button Content="Backtest" Tag="9" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
            <Button Content="Diagnostico" Tag="10" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" MinWidth="120" />
        </StackPanel>

        <TabControl x:Name="MainTabs"
                    Margin="12,6,12,12"
                    ItemContainerStyle="{StaticResource HiddenMainTabItemStyle}"
                    SelectionChanged="MainTabs_SelectionChanged">
            <TabItem Header="Ativos">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1.15*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="190" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Ativos cadastrados" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,16,0" />
                            <TextBlock x:Name="RtdAssetSummaryText" Text="-" Foreground="{StaticResource Muted}" VerticalAlignment="Center" />
                        </StackPanel>
                        <DataGrid x:Name="RtdAssetsGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  SelectionMode="Single"
                                  SelectionChanged="RtdAssetsGrid_SelectionChanged"
                                  MouseDoubleClick="RtdAssetsGrid_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="130" />
                                <DataGridTextColumn Header="Ativo" Binding="{Binding Asset}" Width="120" />
                                <DataGridTextColumn Header="Cotacao" Binding="{Binding QuoteCode}" Width="135" />
                                <DataGridTextColumn Header="Book" Binding="{Binding BookTopic}" Width="80" />
                                <DataGridTextColumn Header="Times" Binding="{Binding TimesTopic}" Width="80" />
                                <DataGridTextColumn Header="CSV" Binding="{Binding CsvText}" Width="140" />
                                <DataGridTextColumn Header="On" Binding="{Binding EnabledText}" Width="70" />
                                <DataGridTextColumn Header="C/B/T" Binding="{Binding ChannelsText}" Width="80" />
                                <DataGridTextColumn Header="Foco" Binding="{Binding FocusText}" Width="60" />
                                <DataGridTextColumn Header="ULT" Binding="{Binding LastText}" Width="90" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Cadastro do ativo" FontSize="15" FontWeight="Bold" Margin="0,0,0,8" />
                                    <TextBlock Text="Nome" Foreground="{StaticResource Muted}" />
                                    <TextBox x:Name="AssetNameInput" Margin="0,3,0,7" />
                                    <TextBlock Text="Codigo Cotacao" Foreground="{StaticResource Muted}" />
                                    <TextBox x:Name="QuoteCodeInput" Margin="0,3,0,7" KeyDown="NewAssetInput_KeyDown" />
                                    <TextBox x:Name="NewAssetInput" Visibility="Collapsed" />
                                    <TextBlock Text="Canal Book" Foreground="{StaticResource Muted}" />
                                    <TextBox x:Name="BookTopicInput" Margin="0,3,0,7" />
                                    <TextBlock Text="Canal Times" Foreground="{StaticResource Muted}" />
                                    <TextBox x:Name="TimesTopicInput" Margin="0,3,0,10" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <CheckBox x:Name="QuoteEnabledInput" Content="Cotacao" IsChecked="True" />
                                        <CheckBox x:Name="BookEnabledInput" Content="Book" />
                                        <CheckBox x:Name="TimesEnabledInput" Content="Times" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Button x:Name="AddAssetButton" Content="Adicionar" Click="AddAssetButton_Click" />
                                        <Button x:Name="SaveAssetButton" Content="Salvar" Click="SaveAssetButton_Click" />
                                        <Button x:Name="RemoveAssetButton" Content="Remover" Click="RemoveAssetButton_Click" Margin="0" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="FocusAssetButton" Content="Focar" Click="FocusAssetButton_Click" />
                                        <Button x:Name="StartAssetButton" Content="Ligar" Click="StartAssetButton_Click" />
                                        <Button x:Name="StopAssetButton" Content="Desligar" Click="StopAssetButton_Click" Margin="0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border x:Name="CsvDropZone"
                                    Background="{StaticResource Panel}"
                                    BorderBrush="{StaticResource Border}"
                                    BorderThickness="1"
                                    Padding="12"
                                    AllowDrop="True"
                                    Drop="CsvDropZone_Drop"
                                    MouseLeftButtonDown="CsvDropZone_MouseLeftButtonDown">
                                <StackPanel>
                                    <TextBlock Text="CSV Historico" FontSize="15" FontWeight="Bold" />
                                    <TextBlock x:Name="CsvFileText" Text="Nenhum arquivo carregado" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,8,0,4" />
                                    <TextBlock x:Name="CsvCountText" Text="0 pregoes" Foreground="{StaticResource Muted}" />
                                    <TextBox x:Name="CsvPathInput" Margin="0,8,0,6" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="SelectCsvPanelButton" Content="Selecionar arquivo" Click="SelectCsvPanelButton_Click" PreviewMouseLeftButtonDown="SelectCsvPanelButton_PreviewMouseLeftButtonDown" />
                                        <Button x:Name="LoadCsvPathButton" Content="Carregar caminho" Click="LoadCsvPathButton_Click" PreviewMouseLeftButtonDown="LoadCsvPathButton_PreviewMouseLeftButtonDown" Margin="0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.ColumnSpan="2" Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1.3*" />
                        </Grid.ColumnDefinitions>
                        <DataGrid x:Name="RtdChannelsGrid"
                                  AutoGenerateColumns="False"
                                  SelectionMode="Single"
                                  Margin="0,0,12,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Ativo" Binding="{Binding Asset}" Width="140" />
                                <DataGridTextColumn Header="Foco" Binding="{Binding FocusText}" Width="70" />
                                <DataGridTemplateColumn Header="Cotacao" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding Cotacao}" HorizontalAlignment="Center" Click="CotacaoChannelCheckBox_Click" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Book" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding Book}" HorizontalAlignment="Center" Click="BookChannelCheckBox_Click" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Times" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding Times}" HorizontalAlignment="Center" Click="TimesChannelCheckBox_Click" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <ItemsControl x:Name="WarningsList" Grid.Column="1" />
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Cotacao">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <UniformGrid Columns="6" Margin="0,0,0,12">
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Abertura" Foreground="{StaticResource Muted}" />
                            <TextBox x:Name="OpenInput" Margin="0,3,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Maxima" Foreground="{StaticResource Muted}" />
                            <TextBox x:Name="HighInput" Margin="0,3,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Minima" Foreground="{StaticResource Muted}" />
                            <TextBox x:Name="LowInput" Margin="0,3,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Preco atual" Foreground="{StaticResource Muted}" />
                            <TextBox x:Name="ManualPriceInput" Margin="0,3,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="VWAP / MED" Foreground="{StaticResource Muted}" />
                            <TextBox x:Name="VwapInput" Margin="0,3,0,0" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Volume" Foreground="{StaticResource Muted}" />
                            <TextBox x:Name="VolumeInput" Margin="0,3,0,0" />
                        </StackPanel>
                    </UniformGrid>
                    <DataGrid x:Name="QuoteFieldsGrid" Grid.Row="1" AutoGenerateColumns="True" />
                </Grid>
            </TabItem>

            <TabItem Header="DOM / Book">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition Width="0.9*" />
                    </Grid.ColumnDefinitions>
                    <DataGrid x:Name="DomGrid" Grid.Column="0" AutoGenerateColumns="False" Margin="0,0,10,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="AskVol" Binding="{Binding AskVol}" Width="90" />
                            <DataGridTextColumn Header="Preco" Binding="{Binding PriceText}" Width="90" />
                            <DataGridTextColumn Header="BidVol" Binding="{Binding BidVol}" Width="90" />
                            <DataGridTextColumn Header="Flags" Binding="{Binding Flags}" Width="90" />
                            <DataGridTextColumn Header="Marcacoes" Binding="{Binding Markings}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <DataGrid x:Name="BookGrid" Grid.Column="1" AutoGenerateColumns="True" Margin="0,0,10,0" />
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DataGrid x:Name="TapeGrid" Grid.Row="0" AutoGenerateColumns="True" Margin="0,0,0,10" />
                        <DataGrid x:Name="DomLevelsGrid" Grid.Row="1" AutoGenerateColumns="True" />
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Tape">
                <DataGrid x:Name="FlowTapeGrid" Margin="0,10,0,0" AutoGenerateColumns="True" />
            </TabItem>

            <TabItem Header="Order Flow">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="190" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="OrderFlowSummaryGrid" AutoGenerateColumns="True" Margin="0,0,0,10" />
                    <DataGrid x:Name="OrderFlowWindowsGrid" Grid.Row="1" AutoGenerateColumns="True" />
                </Grid>
            </TabItem>

            <TabItem Header="Volume Profile">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="380" />
                        <RowDefinition Height="125" />
                        <RowDefinition Height="145" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <charts:VolumeProfileChartControl x:Name="ProfileChartControl" Margin="0,0,0,10" />
                    <DataGrid x:Name="ProfileSummaryGrid" Grid.Row="1" AutoGenerateColumns="True" Margin="0,0,0,10" />
                    <DataGrid x:Name="ProfileNodesGrid" Grid.Row="2" AutoGenerateColumns="True" Margin="0,0,0,10" />
                    <DataGrid x:Name="ProfileGrid" Grid.Row="3" AutoGenerateColumns="True" />
                </Grid>
            </TabItem>

            <TabItem Header="Setups">
                <DataGrid x:Name="FlowSignalsGrid" Margin="0,10,0,0" AutoGenerateColumns="True" />
            </TabItem>

            <TabItem Header="Niveis">
                <TabControl Margin="0,10,0,0">
                    <TabItem Header="Principais">
                        <DataGrid x:Name="LevelsGrid" Margin="0,10,0,0" AutoGenerateColumns="True" />
                    </TabItem>
                    <TabItem Header="Abertura">
                        <DataGrid x:Name="OpeningGrid" Margin="0,10,0,0" AutoGenerateColumns="True" />
                    </TabItem>
                    <TabItem Header="POC">
                        <DataGrid x:Name="PocGrid" Margin="0,10,0,0" AutoGenerateColumns="True" />
                    </TabItem>
                    <TabItem Header="Variacao %">
                        <DataGrid x:Name="PercentGrid" Margin="0,10,0,0" AutoGenerateColumns="True" />
                    </TabItem>
                    <TabItem Header="Confluencia">
                        <DataGrid x:Name="ConfluenceGrid" Margin="0,10,0,0" AutoGenerateColumns="True" />
                    </TabItem>
                </TabControl>
            </TabItem>

            <TabItem Header="Grafico">
                <charts:NativeChartControl x:Name="ChartControl" Margin="0,10,0,0" />
            </TabItem>

            <TabItem Header="Backtest">
                <DataGrid x:Name="BacktestGrid" Margin="0,10,0,0" AutoGenerateColumns="True" />
            </TabItem>

            <TabItem Header="Diagnostico">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="190" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <UniformGrid Columns="3" Margin="0,0,0,10">
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Campos assinados" Foreground="{StaticResource Muted}" />
                            <TextBlock x:Name="FieldsText" Text="-" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Poll RTD" Foreground="{StaticResource Muted}" />
                            <TextBlock x:Name="PollText" Text="-" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Metricas" Foreground="{StaticResource Muted}" />
                            <ItemsControl x:Name="MetricsList" />
                        </StackPanel>
                    </UniformGrid>
                    <TextBox x:Name="LastErrorText"
                             Grid.Row="1"
                             Text="-"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             IsReadOnly="True"
                             Margin="0,0,0,10" />
                    <DataGrid x:Name="RtdSourcesGrid"
                              Grid.Row="2"
                              AutoGenerateColumns="False"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Fonte" Binding="{Binding Name}" Width="170" />
                            <DataGridTextColumn Header="Ativo" Binding="{Binding Asset}" Width="110" />
                            <DataGridTextColumn Header="Topico" Binding="{Binding Topic}" Width="110" />
                            <DataGridTextColumn Header="Papel" Binding="{Binding Role}" Width="120" />
                            <DataGridTextColumn Header="On" Binding="{Binding EnabledText}" Width="70" />
                            <DataGridTextColumn Header="Campos" Binding="{Binding FieldsText}" Width="260" />
                            <DataGridTextColumn Header="Indices" Binding="{Binding IndexText}" Width="80" />
                            <DataGridTextColumn Header="Poll" Binding="{Binding PollText}" Width="70" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                            <DataGridTextColumn Header="Updates" Binding="{Binding UpdatesText}" Width="90" />
                            <DataGridTextColumn Header="Erro" Binding="{Binding LastError}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
