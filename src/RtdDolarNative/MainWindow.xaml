                                                           Foreground="{StaticResource Muted}"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center"
                                                           Margin="4,0,6,0" />
                                                <TextBlock Text="Ref:"
                                                           Foreground="{StaticResource Muted}"
