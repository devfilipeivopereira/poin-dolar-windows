                                                          ToolTip="Maxima e minima dos ultimos 7 pregoes"
                                                          VerticalContentAlignment="Center"
                                                          Checked="ChartLineVisibility_Checked"
                                                          Unchecked="ChartLineVisibility_Checked" />
                                            </StackPanel>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
