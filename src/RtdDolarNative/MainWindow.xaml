<Window x:Class="RtdDolarNative.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:charts="clr-namespace:RtdDolarNative.Charts"
        Title="Poin Dolar Windows"
        Height="820"
        Width="1380"
        MinHeight="720"
        MinWidth="1120"
        Background="#000000"
        FontFamily="Consolas"
        FontSize="12">
    <Window.Resources>
        <SolidColorBrush x:Key="Bg" Color="#000000" />
        <SolidColorBrush x:Key="Panel" Color="#0B0C0A" />
        <SolidColorBrush x:Key="Panel2" Color="#111411" />
        <SolidColorBrush x:Key="InputBg" Color="#050605" />
        <SolidColorBrush x:Key="Border" Color="#303844" />
        <SolidColorBrush x:Key="GridLine" Color="#222A33" />
        <SolidColorBrush x:Key="Text" Color="#E6EDF3" />
        <SolidColorBrush x:Key="Muted" Color="#A9B3BF" />
        <SolidColorBrush x:Key="Accent" Color="#00E676" />
        <SolidColorBrush x:Key="Warn" Color="#FFB800" />
        <SolidColorBrush x:Key="Danger" Color="#FF3B30" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Panel2}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#101711" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#003B24" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="#050605" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#20252B" />
                                <Setter Property="Foreground" Value="{StaticResource Muted}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Padding" Value="10,5" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="MinHeight" Value="28" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridLine}" />
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource GridLine}" />
            <Setter Property="RowBackground" Value="{StaticResource InputBg}" />
            <Setter Property="AlternatingRowBackground" Value="{StaticResource Panel}" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AutoGenerateColumns" Value="True" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="AlternationCount" Value="2" />
            <Setter Property="EnableRowVirtualization" Value="True" />
            <Setter Property="EnableColumnVirtualization" Value="True" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
            <Setter Property="ColumnHeaderHeight" Value="28" />
            <Setter Property="RowHeight" Value="24" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource Panel2}" />
            <Setter Property="Foreground" Value="{StaticResource Muted}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{StaticResource Panel}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#111D16" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#003B24" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SeverityDataGridRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity}" Value="Critico">
                    <Setter Property="Background" Value="#2A0606" />
                    <Setter Property="Foreground" Value="#FFD4D0" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="Aviso">
                    <Setter Property="Background" Value="#241900" />
                    <Setter Property="Foreground" Value="{StaticResource Warn}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="Normal">
                    <Setter Property="Background" Value="#061A10" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="Info">
                    <Setter Property="Background" Value="#071018" />
                    <Setter Property="Foreground" Value="{StaticResource Muted}" />
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#003B24" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusDataGridRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="connected">
                    <Setter Property="Background" Value="#061A10" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="pronto">
                    <Setter Property="Background" Value="#101711" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="aguardando">
                    <Setter Property="Background" Value="#241900" />
                    <Setter Property="Foreground" Value="{StaticResource Warn}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="lento">
                    <Setter Property="Background" Value="#241900" />
                    <Setter Property="Foreground" Value="{StaticResource Warn}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="atrasado">
                    <Setter Property="Background" Value="#2A0606" />
                    <Setter Property="Foreground" Value="#FFD4D0" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="desligado">
                    <Setter Property="Background" Value="#090A09" />
                    <Setter Property="Foreground" Value="{StaticResource Muted}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="ativo off">
                    <Setter Property="Background" Value="#090A09" />
                    <Setter Property="Foreground" Value="{StaticResource Muted}" />
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#003B24" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FlowMapDataGridRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Zone}" Value="ASK">
                    <Setter Property="Background" Value="#170606" />
                    <Setter Property="Foreground" Value="#FFD4D0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Zone}" Value="BID">
                    <Setter Property="Background" Value="#061A10" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Zone}" Value="PROFILE">
                    <Setter Property="Background" Value="#241900" />
                    <Setter Property="Foreground" Value="{StaticResource Warn}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Zone}" Value="ULT">
                    <Setter Property="Background" Value="#003B24" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#003B24" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource GridLine}" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#003B24" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                    <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource Bg}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{StaticResource Panel2}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinHeight" Value="34" />
        </Style>

        <Style x:Key="TopNavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="46" />
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style x:Key="TopNavGroupStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Muted}" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TopNavGroupBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Bg}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="Padding" Value="0,0,5,0" />
            <Setter Property="Margin" Value="0,0,5,0" />
        </Style>

        <Style x:Key="HiddenMainTabItemStyle" TargetType="TabItem">
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Arquivo">
                <MenuItem Header="Carregar CSV" InputGestureText="Ctrl+O" Click="MenuLoadCsv_Click" />
            </MenuItem>
            <MenuItem Header="Operacao">
                <MenuItem Header="Mesa" InputGestureText="Ctrl+1" Tag="0" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Ativos" InputGestureText="Ctrl+2" Tag="1" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Monitor" InputGestureText="F11" Tag="14" Click="NavigateMenuItem_Click" />
                <Separator />
                <MenuItem Header="Conectar / Desconectar" InputGestureText="F5" Click="MenuConnect_Click" />
                <MenuItem Header="Modo manual" InputGestureText="Ctrl+M" Click="MenuManual_Click" />
                <MenuItem Header="Prontidao RTD" InputGestureText="Ctrl+R" Tag="1" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Focar ativo selecionado" InputGestureText="Ctrl+F" Click="MenuFocusAsset_Click" />
                <MenuItem Header="Fontes padrao" Click="MenuDefaultSources_Click" />
                <Separator />
                <MenuItem Header="Diagnostico" InputGestureText="Ctrl+0" Tag="13" Click="NavigateMenuItem_Click" />
            </MenuItem>
            <MenuItem Header="Mercado">
                <MenuItem Header="Cotacao" Tag="2" Click="NavigateMenuItem_Click" />
                <MenuItem Header="DOM / Book" InputGestureText="Ctrl+3" Tag="3" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Tape" InputGestureText="Ctrl+4" Tag="4" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Grafico" InputGestureText="Ctrl+9" Tag="9" Click="NavigateMenuItem_Click" />
            </MenuItem>
            <MenuItem Header="Fluxo">
                <MenuItem Header="Order Flow" InputGestureText="Ctrl+5" Tag="5" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Mapa de Fluxo" InputGestureText="Ctrl+Shift+F" Tag="19" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Volume Profile" InputGestureText="Ctrl+6" Tag="6" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Setups" InputGestureText="Ctrl+7" Tag="7" Click="NavigateMenuItem_Click" />
            </MenuItem>
            <MenuItem Header="Analise">
                <MenuItem Header="Calcular" InputGestureText="F6" Click="MenuRecalculate_Click" />
                <Separator />
                <MenuItem Header="Scanner" InputGestureText="F3" Tag="18" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Oportunidades" InputGestureText="F2" Tag="16" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Indicadores" InputGestureText="Ctrl+Shift+I" Tag="20" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Niveis" InputGestureText="Ctrl+8" Tag="8" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Backtest" Tag="10" Click="NavigateMenuItem_Click" />
            </MenuItem>
            <MenuItem Header="Controle">
                <MenuItem Header="Risco operacional" InputGestureText="F9" Tag="11" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Alertas" InputGestureText="F8" Tag="12" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Historico" InputGestureText="F10" Tag="17" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Diagnostico" InputGestureText="Ctrl+0" Tag="13" Click="NavigateMenuItem_Click" />
                <Separator />
                <MenuItem Header="Abrir configuracao" Click="MenuOpenConfig_Click" />
                <MenuItem Header="Abrir pasta de logs" Click="MenuOpenLogFolder_Click" />
            </MenuItem>
            <MenuItem Header="Janelas">
                <MenuItem Header="Mesa" InputGestureText="Ctrl+1" Tag="0" Click="NavigateMenuItem_Click" />
                <Separator />
                <MenuItem Header="Ativos" InputGestureText="Ctrl+2" Tag="1" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Monitor" InputGestureText="F11" Tag="14" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Diagnostico" InputGestureText="Ctrl+0" Tag="13" Click="NavigateMenuItem_Click" />
                <Separator />
                <MenuItem Header="Cotacao" Tag="2" Click="NavigateMenuItem_Click" />
                <MenuItem Header="DOM / Book" InputGestureText="Ctrl+3" Tag="3" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Tape" InputGestureText="Ctrl+4" Tag="4" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Grafico" InputGestureText="Ctrl+9" Tag="9" Click="NavigateMenuItem_Click" />
                <Separator />
                <MenuItem Header="Order Flow" InputGestureText="Ctrl+5" Tag="5" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Mapa de Fluxo" InputGestureText="Ctrl+Shift+F" Tag="19" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Volume Profile" InputGestureText="Ctrl+6" Tag="6" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Setups" InputGestureText="Ctrl+7" Tag="7" Click="NavigateMenuItem_Click" />
                <Separator />
                <MenuItem Header="Scanner" InputGestureText="F3" Tag="18" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Oportunidades" InputGestureText="F2" Tag="16" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Indicadores" InputGestureText="Ctrl+Shift+I" Tag="20" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Niveis" InputGestureText="Ctrl+8" Tag="8" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Backtest" Tag="10" Click="NavigateMenuItem_Click" />
                <Separator />
                <MenuItem Header="Risco operacional" InputGestureText="F9" Tag="11" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Alertas" InputGestureText="F8" Tag="12" Click="NavigateMenuItem_Click" />
                <MenuItem Header="Historico" InputGestureText="F10" Tag="17" Click="NavigateMenuItem_Click" />
                <Separator />
                <MenuItem Header="Aba anterior" InputGestureText="Ctrl+Shift+Tab" Click="MenuPreviousTab_Click" />
                <MenuItem Header="Proxima aba" InputGestureText="Ctrl+Tab" Click="MenuNextTab_Click" />
            </MenuItem>
            <MenuItem Header="Ajuda">
                <MenuItem Header="Atalhos" InputGestureText="F1" Tag="15" Click="NavigateMenuItem_Click" />
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Top"
                Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,0,1"
                Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Poin Dolar Windows"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,14,0" />
                    <Border x:Name="StatusBadgeBorder"
                            Background="#303844"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1"
                            Padding="10,4">
                        <TextBlock x:Name="StatusText" Text="starting" FontWeight="Bold" />
                    </Border>
                </StackPanel>

                <UniformGrid Grid.Column="1" Columns="8" Margin="22,0" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Ativo" Foreground="{StaticResource Muted}" />
                        <TextBlock x:Name="AssetText" Text="-" FontWeight="Bold" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="ULT" Foreground="{StaticResource Muted}" />
                        <TextBlock x:Name="PriceText" Text="-" Foreground="{StaticResource Accent}" FontSize="18" FontWeight="Bold" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Bid / Ask" Foreground="{StaticResource Muted}" />
                        <TextBlock x:Name="BidAskText" Text="-" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Volume" Foreground="{StaticResource Muted}" />
                        <TextBlock x:Name="VolumeText" Text="-" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Hora Profit" Foreground="{StaticResource Muted}" />
                        <TextBlock x:Name="ProfitTimeText" Text="-" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Snapshot" Foreground="{StaticResource Muted}" />
                        <TextBlock x:Name="SnapshotAgeText" Text="-" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Updates" Foreground="{StaticResource Muted}" />
                        <TextBlock x:Name="UpdatesText" Text="0" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Tela" Foreground="{StaticResource Muted}" />
                        <TextBlock x:Name="WorkspaceText"
                                   Text="Mesa"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </UniformGrid>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ConnectButton" Content="Conectar" Click="ConnectButton_Click" />
                    <Button x:Name="ManualButton" Content="Modo manual" Click="ManualButton_Click" />
                    <Button x:Name="LoadCsvButton" Content="Carregar CSV" Click="LoadCsvButton_Click" PreviewMouseLeftButtonDown="LoadCsvButton_PreviewMouseLeftButtonDown" />
                    <Button x:Name="RecalcButton" Content="Calcular" Click="RecalcButton_Click" Margin="0" />
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,1,0,0"
                Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.55*" />
                    <ColumnDefinition Width="1.85*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusBarText" Text="RTD idle" />
                <TextBlock x:Name="WorkspaceHintText" Grid.Column="1" Text="Mesa | Mesa operacional de analise" Foreground="{StaticResource Muted}" />
                <TextBlock x:Name="DataQualityText" Grid.Column="2" Text="Qualidade -" Foreground="{StaticResource Muted}" />
                <TextBlock x:Name="FlowStateText" Grid.Column="3" Text="Fluxo -" Foreground="{StaticResource Muted}" />
                <TextBlock x:Name="QueueStateText" Grid.Column="4" Text="Fila -" Foreground="{StaticResource Muted}" HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top"
                Background="{StaticResource Bg}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,0,1"
                Padding="10,5">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <StackPanel x:Name="TopNavigation" Orientation="Horizontal">

                <Border Style="{StaticResource TopNavGroupBorderStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Operacao" Style="{StaticResource TopNavGroupStyle}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Mesa" Tag="0" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                            <Button Content="Ativos" Tag="1" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                            <Button Content="Monitor" Tag="14" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                            <Button Content="Diag" Tag="13" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource TopNavGroupBorderStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Mercado" Style="{StaticResource TopNavGroupStyle}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Cotacao" Tag="2" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                            <Button Content="DOM" Tag="3" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                            <Button Content="Tape" Tag="4" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                            <Button Content="Grafico" Tag="9" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource TopNavGroupBorderStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Fluxo" Style="{StaticResource TopNavGroupStyle}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Order" Tag="5" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" MinWidth="54" />
                            <Button Content="Mapa" Tag="19" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                            <Button Content="Profile" Tag="6" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" MinWidth="60" />
                            <Button Content="Setups" Tag="7" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource TopNavGroupBorderStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Analise" Style="{StaticResource TopNavGroupStyle}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Scanner" Tag="18" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                            <Button Content="Oportun." Tag="16" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" MinWidth="78" />
                            <Button Content="Indic." Tag="20" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" MinWidth="62" />
                            <Button Content="Niveis" Tag="8" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                            <Button Content="Back" Tag="10" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource TopNavGroupBorderStyle}" BorderThickness="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Controle" Style="{StaticResource TopNavGroupStyle}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Risco" Tag="11" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                            <Button Content="Alertas" Tag="12" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                            <Button Content="Hist" Tag="17" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <TabControl x:Name="MainTabs"
                    Margin="12,6,12,12"
                    ItemContainerStyle="{StaticResource HiddenMainTabItemStyle}"
                    SelectionChanged="MainTabs_SelectionChanged">
            <TabItem Header="Mesa">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="168" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <UniformGrid Columns="4" Margin="0,0,0,10">
                        <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="12" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Resumo Mercado" Foreground="{StaticResource Muted}" />
                                <TextBlock x:Name="DashboardAssetText" Text="-" FontSize="18" FontWeight="Bold" Margin="0,5,0,0" />
                                <TextBlock x:Name="DashboardPriceText" Text="-" Foreground="{StaticResource Accent}" FontSize="24" FontWeight="Bold" Margin="0,6,0,0" />
                                <TextBlock x:Name="DashboardBidAskText" Text="Bid / Ask -" Foreground="{StaticResource Muted}" Margin="0,5,0,0" />
                                <TextBlock x:Name="DashboardVolumeText" Text="Volume -" Foreground="{StaticResource Muted}" Margin="0,3,0,0" />
                                <TextBlock x:Name="DashboardSnapshotText" Text="Snapshot -" Foreground="{StaticResource Muted}" Margin="0,3,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="12" Margin="0,0,10,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Prontidao RTD" Foreground="{StaticResource Muted}" />
                                <TextBlock x:Name="DashboardRtdText" Grid.Row="1" Text="-" FontWeight="Bold" Margin="0,5,0,8" />
                                <DataGrid x:Name="DashboardChannelsGrid"
                                          Grid.Row="2"
                                          AutoGenerateColumns="False"
                                          HeadersVisibility="Column"
                                          RowHeight="22"
                                          ColumnHeaderHeight="24">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Canal" Binding="{Binding Name}" Width="64" />
                                        <DataGridTextColumn Header="Topico" Binding="{Binding Value}" Width="*" />
                                        <DataGridTextColumn Header="Status" Binding="{Binding Detail}" Width="82" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="12" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Fluxo Agora" Foreground="{StaticResource Muted}" />
                                <TextBlock x:Name="DashboardFlowText" Text="Qualidade -" FontWeight="Bold" Margin="0,5,0,0" />
                                <TextBlock x:Name="DashboardDeltaText" Text="Delta -" Foreground="{StaticResource Muted}" Margin="0,6,0,0" />
                                <TextBlock x:Name="DashboardMicroText" Text="Microbias -" Foreground="{StaticResource Muted}" Margin="0,3,0,0" />
                                <TextBlock x:Name="DashboardVwapText" Text="VWAP -" Foreground="{StaticResource Muted}" Margin="0,3,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="12" Margin="0">
                            <StackPanel>
                                <TextBlock Text="Volume Profile" Foreground="{StaticResource Muted}" />
                                <TextBlock x:Name="DashboardProfileText" Text="POC -" FontWeight="Bold" Margin="0,5,0,0" />
                                <TextBlock x:Name="DashboardProfileDetailText" Text="VAH / VAL -" Foreground="{StaticResource Muted}" Margin="0,6,0,0" />
                                <TextBlock x:Name="DashboardCsvText" Text="CSV -" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,3,0,0" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.35*" />
                            <ColumnDefinition Width="1.05*" />
                            <ColumnDefinition Width="0.78*" />
                        </Grid.ColumnDefinitions>

                        <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="10" Margin="0,0,10,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Grafico e contexto" FontSize="15" FontWeight="Bold" Margin="0,0,0,8" />
                                <charts:NativeChartControl x:Name="DashboardChartControl" Grid.Row="1" />
                            </Grid>
                        </Border>

                        <Grid Grid.Column="1" Margin="0,0,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1.05*" />
                                <RowDefinition Height="0.95*" />
                            </Grid.RowDefinitions>

                            <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Oportunidades" FontSize="15" FontWeight="Bold" Margin="0,0,0,8" />
                                    <DataGrid x:Name="DashboardSignalsGrid"
                                              Grid.Row="1"
                                              AutoGenerateColumns="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Ativo" Binding="{Binding Asset}" Width="92" />
                                            <DataGridTextColumn Header="Setup" Binding="{Binding Setup}" Width="130" />
                                            <DataGridTextColumn Header="Direcao" Binding="{Binding Direction}" Width="70" />
                                            <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="56" />
                                            <DataGridTextColumn Header="Nivel" Binding="{Binding Level}" Width="130" />
                                            <DataGridTextColumn Header="Motivos" Binding="{Binding Reasons}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Niveis proximos" FontSize="15" FontWeight="Bold" Margin="0,0,0,8" />
                                    <DataGrid x:Name="DashboardLevelsGrid"
                                              Grid.Row="1"
                                              AutoGenerateColumns="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Preco" Binding="{Binding Price}" Width="82" />
                                            <DataGridTextColumn Header="Nivel" Binding="{Binding Label}" Width="128" />
                                            <DataGridTextColumn Header="Fonte" Binding="{Binding Source}" Width="82" />
                                            <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="56" />
                                            <DataGridTextColumn Header="Dist" Binding="{Binding Distance}" Width="70" />
                                            <DataGridTextColumn Header="Evidencia" Binding="{Binding Evidence}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1.05*" />
                                <RowDefinition Height="0.9*" />
                                <RowDefinition Height="0.7*" />
                            </Grid.RowDefinitions>

                            <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="DOM" FontSize="15" FontWeight="Bold" Margin="0,0,0,8" />
                                    <DataGrid x:Name="DashboardDomGrid"
                                              Grid.Row="1"
                                              AutoGenerateColumns="False"
                                              RowHeight="21"
                                              ColumnHeaderHeight="24">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Venda" Binding="{Binding AskVol}" Width="58" />
                                            <DataGridTextColumn Header="Preco" Binding="{Binding PriceText}" Width="82" />
                                            <DataGridTextColumn Header="Compra" Binding="{Binding BidVol}" Width="64" />
                                            <DataGridTextColumn Header="Niveis" Binding="{Binding Markings}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Tape" FontSize="15" FontWeight="Bold" Margin="0,0,0,8" />
                                    <DataGrid x:Name="DashboardTapeGrid"
                                              Grid.Row="1"
                                              AutoGenerateColumns="False"
                                              RowHeight="21"
                                              ColumnHeaderHeight="24">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Hora" Binding="{Binding Time}" Width="76" />
                                            <DataGridTextColumn Header="Preco" Binding="{Binding Price}" Width="82" />
                                            <DataGridTextColumn Header="Qtd" Binding="{Binding Quantity}" Width="56" />
                                            <DataGridTextColumn Header="Agr" Binding="{Binding Aggressor}" Width="60" />
                                            <DataGridTextColumn Header="Qual" Binding="{Binding Quality}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Janelas de fluxo" FontSize="15" FontWeight="Bold" Margin="0,0,0,8" />
                                    <DataGrid x:Name="DashboardWindowsGrid"
                                              Grid.Row="1"
                                              AutoGenerateColumns="False"
                                              RowHeight="21"
                                              ColumnHeaderHeight="24">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Jan" Binding="{Binding Window}" Width="44" />
                                            <DataGridTextColumn Header="T" Binding="{Binding TradeCount}" Width="42" />
                                            <DataGridTextColumn Header="C" Binding="{Binding BuyVolume}" Width="52" />
                                            <DataGridTextColumn Header="V" Binding="{Binding SellVolume}" Width="52" />
                                            <DataGridTextColumn Header="Delta" Binding="{Binding Delta}" Width="58" />
                                            <DataGridTextColumn Header="Ratio" Binding="{Binding DeltaRatio}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Ativos">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1.15*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="160" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Grid.ColumnSpan="2"
                            Background="{StaticResource Panel}"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1"
                            Padding="12"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="2.1*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="Ativo em foco" Foreground="{StaticResource Muted}" />
                                <TextBlock x:Name="FocusedAssetPanelText" Text="-" FontSize="18" FontWeight="Bold" Margin="0,3,0,4" />
                                <TextBlock x:Name="FocusedAssetStatusText" Text="-" Foreground="{StaticResource Muted}" />
                                <TextBlock x:Name="FocusedAssetCsvPanelText" Text="CSV -" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,0" />
                            </StackPanel>

                            <UniformGrid Grid.Column="1" Columns="3" Margin="0,0,16,0">
                                <Border x:Name="QuoteChannelBorder" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="10" Margin="0,0,8,0" Background="{StaticResource InputBg}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Cotacao" FontWeight="Bold" />
                                        <TextBlock x:Name="QuoteChannelStatusText" Grid.Row="1" Text="-" Foreground="{StaticResource Muted}" Margin="0,4,0,0" />
                                        <TextBlock x:Name="QuoteChannelTopicText" Grid.Row="2" Text="-" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,8" />
                                        <Button x:Name="QuoteChannelToggleButton" Grid.Row="3" Content="Ligar" Click="ToggleFocusedQuoteButton_Click" Margin="0" />
                                    </Grid>
                                </Border>

                                <Border x:Name="BookChannelBorder" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="10" Margin="0,0,8,0" Background="{StaticResource InputBg}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Book" FontWeight="Bold" />
                                        <TextBlock x:Name="BookChannelStatusText" Grid.Row="1" Text="-" Foreground="{StaticResource Muted}" Margin="0,4,0,0" />
                                        <TextBlock x:Name="BookChannelTopicText" Grid.Row="2" Text="-" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,8" />
                                        <Button x:Name="BookChannelToggleButton" Grid.Row="3" Content="Ligar" Click="ToggleFocusedBookButton_Click" Margin="0" />
                                    </Grid>
                                </Border>

                                <Border x:Name="TimesChannelBorder" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="10" Margin="0" Background="{StaticResource InputBg}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Times" FontWeight="Bold" />
                                        <TextBlock x:Name="TimesChannelStatusText" Grid.Row="1" Text="-" Foreground="{StaticResource Muted}" Margin="0,4,0,0" />
                                        <TextBlock x:Name="TimesChannelTopicText" Grid.Row="2" Text="-" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,8" />
                                        <Button x:Name="TimesChannelToggleButton" Grid.Row="3" Content="Ligar" Click="ToggleFocusedTimesButton_Click" Margin="0" />
                                    </Grid>
                                </Border>
                            </UniformGrid>

                            <Border Grid.Column="2"
                                    Background="{StaticResource InputBg}"
                                    BorderBrush="{StaticResource Border}"
                                    BorderThickness="1"
                                    Padding="10"
                                    Margin="0,0,12,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Prontidao RTD" FontWeight="Bold" Margin="0,0,10,0" />
                                        <TextBlock x:Name="RtdReadinessSummaryText" Text="-" Foreground="{StaticResource Muted}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock x:Name="RtdReadinessCountsText"
                                               Grid.Row="1"
                                               Text="-"
                                               Foreground="{StaticResource Muted}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,6" />
                                    <DataGrid x:Name="RtdReadinessGrid"
                                              Grid.Row="2"
                                              AutoGenerateColumns="False"
                                              RowHeight="22"
                                              ColumnHeaderHeight="24">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Canal" Binding="{Binding Channel}" Width="62" />
                                            <DataGridTextColumn Header="Assin." Binding="{Binding SubscriptionCount}" Width="60" />
                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="82" />
                                            <DataGridTextColumn Header="Args" Binding="{Binding Formula}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="3" Width="150">
                                <Button Content="Focar selecionado" Click="FocusAssetButton_Click" Margin="0,0,0,8" />
                                <Button Content="Ligar foco" Click="StartAssetButton_Click" Margin="0,0,0,8" />
                                <Button Content="Desligar foco" Click="StopAssetButton_Click" Margin="0,0,0,8" />
                                <Button Content="Diagnostico" Tag="13" Click="TopNavButton_Click" Margin="0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="0" Grid.Row="1" Margin="0,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Ativos cadastrados" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,16,0" />
                            <TextBlock x:Name="RtdAssetSummaryText" Text="-" Foreground="{StaticResource Muted}" VerticalAlignment="Center" />
                        </StackPanel>
                        <DataGrid x:Name="RtdAssetsGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  SelectionMode="Single"
                                  SelectionChanged="RtdAssetsGrid_SelectionChanged"
                                  MouseDoubleClick="RtdAssetsGrid_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="130" />
                                <DataGridTextColumn Header="Ativo" Binding="{Binding Asset}" Width="120" />
                                <DataGridTextColumn Header="Cotacao" Binding="{Binding QuoteCode}" Width="135" />
                                <DataGridTextColumn Header="Book" Binding="{Binding BookTopic}" Width="80" />
                                <DataGridTextColumn Header="Times" Binding="{Binding TimesTopic}" Width="80" />
                                <DataGridTextColumn Header="CSV" Binding="{Binding CsvText}" Width="140" />
                                <DataGridTextColumn Header="On" Binding="{Binding EnabledText}" Width="70" />
                                <DataGridTextColumn Header="C/B/T" Binding="{Binding ChannelsText}" Width="80" />
                                <DataGridTextColumn Header="Foco" Binding="{Binding FocusText}" Width="60" />
                                <DataGridTextColumn Header="ULT" Binding="{Binding LastText}" Width="90" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <ScrollViewer Grid.Column="1" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Cadastro do ativo" FontSize="15" FontWeight="Bold" Margin="0,0,0,8" />
                                    <TextBlock Text="Nome" Foreground="{StaticResource Muted}" />
                                    <TextBox x:Name="AssetNameInput" Margin="0,3,0,7" />
                                    <TextBlock Text="Codigo Cotacao" Foreground="{StaticResource Muted}" />
                                    <TextBox x:Name="QuoteCodeInput" Margin="0,3,0,7" KeyDown="NewAssetInput_KeyDown" />
                                    <TextBox x:Name="NewAssetInput" Visibility="Collapsed" />
                                    <TextBlock Text="Canal Book" Foreground="{StaticResource Muted}" />
                                    <TextBox x:Name="BookTopicInput" Margin="0,3,0,7" />
                                    <TextBlock Text="Canal Times" Foreground="{StaticResource Muted}" />
                                    <TextBox x:Name="TimesTopicInput" Margin="0,3,0,10" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <CheckBox x:Name="QuoteEnabledInput" Content="Cotacao" IsChecked="True" />
                                        <CheckBox x:Name="BookEnabledInput" Content="Book" />
                                        <CheckBox x:Name="TimesEnabledInput" Content="Times" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Button x:Name="AddAssetButton" Content="Adicionar" Click="AddAssetButton_Click" />
                                        <Button x:Name="SaveAssetButton" Content="Salvar" Click="SaveAssetButton_Click" />
                                        <Button x:Name="RemoveAssetButton" Content="Remover" Click="RemoveAssetButton_Click" Margin="0" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="FocusAssetButton" Content="Focar" Click="FocusAssetButton_Click" />
                                        <Button x:Name="StartAssetButton" Content="Ligar" Click="StartAssetButton_Click" />
                                        <Button x:Name="StopAssetButton" Content="Desligar" Click="StopAssetButton_Click" Margin="0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border x:Name="CsvDropZone"
                                    Background="{StaticResource Panel}"
                                    BorderBrush="{StaticResource Border}"
                                    BorderThickness="1"
                                    Padding="12"
                                    AllowDrop="True"
                                    Drop="CsvDropZone_Drop"
                                    MouseLeftButtonDown="CsvDropZone_MouseLeftButtonDown">
                                <StackPanel>
                                    <TextBlock Text="CSV Historico" FontSize="15" FontWeight="Bold" />
                                    <TextBlock x:Name="CsvFileText" Text="Nenhum arquivo carregado" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,8,0,4" />
                                    <TextBlock x:Name="CsvCountText" Text="0 pregoes" Foreground="{StaticResource Muted}" />
                                    <TextBox x:Name="CsvPathInput" Margin="0,8,0,6" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="SelectCsvPanelButton" Content="Selecionar arquivo" Click="SelectCsvPanelButton_Click" PreviewMouseLeftButtonDown="SelectCsvPanelButton_PreviewMouseLeftButtonDown" />
                                        <Button x:Name="LoadCsvPathButton" Content="Carregar caminho" Click="LoadCsvPathButton_Click" PreviewMouseLeftButtonDown="LoadCsvPathButton_PreviewMouseLeftButtonDown" Margin="0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.ColumnSpan="2" Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1.3*" />
                        </Grid.ColumnDefinitions>
                        <DataGrid x:Name="RtdChannelsGrid"
                                  AutoGenerateColumns="False"
                                  SelectionMode="Single"
                                  Margin="0,0,12,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Ativo" Binding="{Binding Asset}" Width="140" />
                                <DataGridTextColumn Header="Foco" Binding="{Binding FocusText}" Width="70" />
                                <DataGridTemplateColumn Header="Cotacao" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding Cotacao}" HorizontalAlignment="Center" Click="CotacaoChannelCheckBox_Click" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Book" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding Book}" HorizontalAlignment="Center" Click="BookChannelCheckBox_Click" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Times" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding Times}" HorizontalAlignment="Center" Click="TimesChannelCheckBox_Click" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border Grid.Column="1"
                                Background="{StaticResource Panel}"
                                BorderBrush="{StaticResource Border}"
                                BorderThickness="1"
                                Padding="10">
                            <ItemsControl x:Name="WarningsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
