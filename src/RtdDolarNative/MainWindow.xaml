                                <TextBlock x:Name="WorkflowHistoryValueText" Text="-" FontSize="15" FontWeight="Bold" Margin="0,4,0,0" />
                                <TextBlock x:Name="WorkflowHistoryStateText" Text="-" Foreground="{StaticResource Muted}" Margin="0,3,0,0" />
