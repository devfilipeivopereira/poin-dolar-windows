                                    <Button Content="Diag" ToolTip="Diagnostico RTD" Tag="13" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource TopNavGroupBorderStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="TopNavMarketLabel" Text="Mercado" Style="{StaticResource TopNavGroupStyle}" />
