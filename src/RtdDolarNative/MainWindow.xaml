                                <TextBlock x:Name="FocusedAssetCsvPanelText" Text="CSV -" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,0" />
                            </StackPanel>

                            <UniformGrid Grid.Column="1" Columns="3" Margin="0,0,16,0">
