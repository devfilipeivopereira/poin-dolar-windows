                                    <Button Content="Scanner" ToolTip="Scanner de ativos" Tag="18" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                                    <Button Content="Oportun." ToolTip="Oportunidades" Tag="16" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" MinWidth="78" />
                                    <Button Content="Indic." ToolTip="Indicadores Quant" Tag="20" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" MinWidth="62" />
