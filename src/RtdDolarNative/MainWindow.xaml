                                    <Button Content="Order" ToolTip="Order Flow" Tag="5" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" MinWidth="54" />
                                    <Button Content="Mapa" ToolTip="Mapa de fluxo" Tag="19" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" />
                                    <Button Content="Heat" ToolTip="Heatmap book + negocios" Tag="21" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" MinWidth="52" />
                                    <Button Content="Profile" ToolTip="Volume Profile" Tag="6" Click="TopNavButton_Click" Style="{StaticResource TopNavButtonStyle}" MinWidth="60" />
