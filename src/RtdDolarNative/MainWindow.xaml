                                                <CheckBox x:Name="ChartShowCandlesCheckBox"
                                                          Content="Candles"
                                                          Tag="{StaticResource ChartLineCandlesBrush}"
                                                          Margin="0,0,8,0"
                                                          Style="{StaticResource TopNavChartLineCheckBoxStyle}"
                                                          VerticalContentAlignment="Center"
                                                          Checked="ChartLineVisibility_Checked"
                                                          Unchecked="ChartLineVisibility_Checked" />
                                                <CheckBox x:Name="ChartShowPriceGridCheckBox"
                                                          Content="Grade"
                                                          Tag="{StaticResource ChartLineGridBrush}"
                                                          Style="{StaticResource TopNavChartLineCheckBoxStyle}"
                                                          Margin="0,0,8,0"
                                                          VerticalContentAlignment="Center"
                                                          Checked="ChartLineVisibility_Checked"
                                                          Unchecked="ChartLineVisibility_Checked" />
                                                <CheckBox x:Name="ChartShowCurrentPriceLineCheckBox"
                                                          Content="Atual"
