<Window x:Class="RtdDolarNative.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:charts="clr-namespace:RtdDolarNative.Charts"
        Title="Poin Dolar Windows"
        Height="820"
        Width="1380"
        MinHeight="720"
        MinWidth="1120"
        Background="#000000"
        FontFamily="Consolas"
        FontSize="12">
    <Window.Resources>
        <SolidColorBrush x:Key="Bg" Color="#000000" />
        <SolidColorBrush x:Key="Panel" Color="#0B0C0A" />
        <SolidColorBrush x:Key="Panel2" Color="#111411" />
        <SolidColorBrush x:Key="InputBg" Color="#050605" />
        <SolidColorBrush x:Key="Border" Color="#303844" />
        <SolidColorBrush x:Key="GridLine" Color="#222A33" />
        <SolidColorBrush x:Key="Text" Color="#E6EDF3" />
        <SolidColorBrush x:Key="Muted" Color="#A9B3BF" />
        <SolidColorBrush x:Key="Accent" Color="#00E676" />
        <SolidColorBrush x:Key="Warn" Color="#FFB800" />
        <SolidColorBrush x:Key="DeepWarn" Color="#B8860B" />
        <SolidColorBrush x:Key="Danger" Color="#FF3B30" />
        <SolidColorBrush x:Key="DomCurrentBg" Color="#5D636B" />
        <SolidColorBrush x:Key="DomBidBg" Color="#10233A" />
        <SolidColorBrush x:Key="DomBidStrongBg" Color="#1A3F6A" />
        <SolidColorBrush x:Key="DomAskBg" Color="#301010" />
        <SolidColorBrush x:Key="DomAskStrongBg" Color="#641818" />
        <SolidColorBrush x:Key="DomBookBuySoftBg" Color="#0C1E31" />
        <SolidColorBrush x:Key="DomBookBuyStrongBg" Color="#153D69" />
        <SolidColorBrush x:Key="DomBookSellSoftBg" Color="#301010" />
        <SolidColorBrush x:Key="DomBookSellStrongBg" Color="#6A1818" />
        <SolidColorBrush x:Key="ChartLineCandlesBrush" Color="#00E676" />
        <SolidColorBrush x:Key="ChartLineGridBrush" Color="#6CB6FF" />
        <SolidColorBrush x:Key="ChartLineCurrentBrush" Color="#FFD166" />
        <SolidColorBrush x:Key="ChartLineConfluenceBrush" Color="#FFB86C" />
        <SolidColorBrush x:Key="ChartLineKeyLevelsBrush" Color="#A6E22E" />
        <SolidColorBrush x:Key="ChartLineRtdBrush" Color="#BD93F9" />
        <SolidColorBrush x:Key="ChartLineProfileBrush" Color="#8BE9FD" />
        <SolidColorBrush x:Key="ChartLineTechnicalBrush" Color="#FF79C6" />
        <SolidColorBrush x:Key="ChartLineMarketBrush" Color="#50FA7B" />
        <SolidColorBrush x:Key="ChartLinePercentBrush" Color="#F8F8F2" />
        <SolidColorBrush x:Key="ChartLineGarchBrush" Color="#BD4DFF" />
        <SolidColorBrush x:Key="ChartLineGarmanBrush" Color="#FFD166" />
        <SolidColorBrush x:Key="ChartLineGaussBrush" Color="#6CB6FF" />
        <SolidColorBrush x:Key="ChartLineStdDevBrush" Color="#F8F8F2" />
        <SolidColorBrush x:Key="ChartLineMaxMin7Brush" Color="#FFB86C" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#0B0C0A" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}" Color="#0B0C0A" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#003B24" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#E6EDF3" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#0B0C0A" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#E6EDF3" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#050605" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#E6EDF3" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#003B24" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#E6EDF3" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#003B24" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#E6EDF3" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HotTrackBrushKey}" Color="#003B24" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Panel2}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#101711" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#003B24" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="#050605" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#20252B" />
                                <Setter Property="Foreground" Value="{StaticResource Muted}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Background" Value="{StaticResource Panel2}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#101711" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#003B24" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="#050605" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#20252B" />
                                <Setter Property="Foreground" Value="{StaticResource Muted}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#003B24" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </Trigger>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#003B24" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </Trigger>
                <Trigger Property="IsSubmenuOpen" Value="True">
                    <Setter Property="Background" Value="#003B24" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{StaticResource Muted}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource Border}" />
            <Setter Property="Margin" Value="4,3" />
            <Setter Property="Height" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="MinHeight" Value="28" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="6,2" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#003B24" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#003B24" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridLine}" />
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource GridLine}" />
            <Setter Property="RowBackground" Value="{StaticResource InputBg}" />
            <Setter Property="AlternatingRowBackground" Value="{StaticResource Panel}" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AutoGenerateColumns" Value="True" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="AlternationCount" Value="2" />
            <Setter Property="EnableRowVirtualization" Value="True" />
            <Setter Property="EnableColumnVirtualization" Value="True" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
            <Setter Property="ColumnHeaderHeight" Value="28" />
            <Setter Property="RowHeight" Value="24" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource Panel2}" />
            <Setter Property="Foreground" Value="{StaticResource Muted}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{StaticResource Panel}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#111D16" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#003B24" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SeverityDataGridRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity}" Value="Critico">
                    <Setter Property="Background" Value="#2A0606" />
                    <Setter Property="Foreground" Value="#FFD4D0" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="Aviso">
                    <Setter Property="Background" Value="#241900" />
                    <Setter Property="Foreground" Value="{StaticResource Warn}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="Normal">
                    <Setter Property="Background" Value="#061A10" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="Info">
                    <Setter Property="Background" Value="#071018" />
                    <Setter Property="Foreground" Value="{StaticResource Muted}" />
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#003B24" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusDataGridRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="connected">
                    <Setter Property="Background" Value="#061A10" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="pronto">
                    <Setter Property="Background" Value="#101711" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="aguardando">
                    <Setter Property="Background" Value="#241900" />
                    <Setter Property="Foreground" Value="{StaticResource Warn}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="lento">
                    <Setter Property="Background" Value="#241900" />
                    <Setter Property="Foreground" Value="{StaticResource Warn}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="atrasado">
                    <Setter Property="Background" Value="#2A0606" />
                    <Setter Property="Foreground" Value="#FFD4D0" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="desligado">
                    <Setter Property="Background" Value="#090A09" />
                    <Setter Property="Foreground" Value="{StaticResource Muted}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="ativo off">
                    <Setter Property="Background" Value="#090A09" />
                    <Setter Property="Foreground" Value="{StaticResource Muted}" />
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#003B24" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RtdCompleteDataGridRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Ao vivo">
                    <Setter Property="Background" Value="#061A10" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Sem valor">
                    <Setter Property="Background" Value="#15130B" />
                    <Setter Property="Foreground" Value="{StaticResource Warn}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Nao assinado">
                    <Setter Property="Background" Value="#080A0D" />
                    <Setter Property="Foreground" Value="{StaticResource Muted}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Desatualizado">
                    <Setter Property="Background" Value="#2A0606" />
                    <Setter Property="Foreground" Value="#FFD4D0" />
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#003B24" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FlowMapDataGridRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Zone}" Value="ASK">
                    <Setter Property="Background" Value="#170606" />
                    <Setter Property="Foreground" Value="#FFD4D0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Zone}" Value="BID">
                    <Setter Property="Background" Value="#061A10" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Zone}" Value="PROFILE">
                    <Setter Property="Background" Value="#241900" />
                    <Setter Property="Foreground" Value="{StaticResource Warn}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Zone}" Value="ULT">
                    <Setter Property="Background" Value="#003B24" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#003B24" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource GridLine}" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#003B24" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                    <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DirectionalDataGridCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Direction}" Value="Compra">
                    <Setter Property="Foreground" Value="{StaticResource Accent}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Direction}" Value="Buy">
                    <Setter Property="Foreground" Value="{StaticResource Accent}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Direction}" Value="Long">
                    <Setter Property="Foreground" Value="{StaticResource Accent}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Direction}" Value="Venda">
                    <Setter Property="Foreground" Value="{StaticResource Danger}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Direction}" Value="Sell">
                    <Setter Property="Foreground" Value="{StaticResource Danger}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Direction}" Value="Short">
                    <Setter Property="Foreground" Value="{StaticResource Danger}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Direction}" Value="Neutro">
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                    <Setter Property="FontWeight" Value="Normal" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Suporte">
                    <Setter Property="Foreground" Value="{StaticResource Accent}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="val">
                    <Setter Property="Foreground" Value="{StaticResource Accent}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="Resistencia">
                    <Setter Property="Foreground" Value="{StaticResource Danger}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="vah">
                    <Setter Property="Foreground" Value="{StaticResource Danger}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RtdCompleteValueCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Direction}" Value="Compra">
                    <Setter Property="Foreground" Value="{StaticResource Accent}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Direction}" Value="Venda">
                    <Setter Property="Foreground" Value="{StaticResource Danger}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Direction}" Value="Neutro">
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                    <Setter Property="FontWeight" Value="Normal" />
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#003B24" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LevelsMapRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Direction}" Value="Venda">
                    <Setter Property="Background" Value="#190707" />
                    <Setter Property="Foreground" Value="#FFD4D0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Direction}" Value="Sell">
                    <Setter Property="Background" Value="#190707" />
                    <Setter Property="Foreground" Value="#FFD4D0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Direction}" Value="Short">
                    <Setter Property="Background" Value="#190707" />
                    <Setter Property="Foreground" Value="#FFD4D0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Direction}" Value="Compra">
                    <Setter Property="Background" Value="#07180F" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Direction}" Value="Buy">
                    <Setter Property="Background" Value="#07180F" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Direction}" Value="Long">
                    <Setter Property="Background" Value="#07180F" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Direction}" Value="Neutro">
                    <Setter Property="Background" Value="#2A2108" />
                    <Setter Property="Foreground" Value="#FFF1C1" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Zone}" Value="Sell">
                    <Setter Property="Background" Value="#190707" />
                    <Setter Property="Foreground" Value="#FFD4D0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Zone}" Value="Opening">
                    <Setter Property="Background" Value="#2A2108" />
                    <Setter Property="Foreground" Value="#FFF1C1" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Zone}" Value="Buy">
                    <Setter Property="Background" Value="#07180F" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#003B24" />
                    <Setter Property="Foreground" Value="{StaticResource Text}" />
                </Trigger>
            </Style.Triggers>
